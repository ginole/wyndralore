# Copy this file to .env and fill in real values before deploying.

# Postgres connection strings (e.g. from Vercel Storage / Neon).
# DATABASE_URL: pooled connection, used by the app at runtime.
# DATABASE_URL_UNPOOLED: direct connection, used only for `prisma migrate` (see schema.prisma
# `directUrl`) — pooled/pgbouncer connections can't run schema migrations reliably.
DATABASE_URL="postgresql://user:password@host-pooler:5432/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth — used to sign user + admin session cookies. Generate a long random string.
SESSION_SECRET="replace-with-a-long-random-string"

# Admin panel (PRD §5.4) — password for the /admin dashboard.
ADMIN_PASSWORD="replace-with-a-strong-password"

# Wise payments (PRD §5) — from your Wise account. Only the fields you set are shown on the
# order/payment page, in this order: name, account number, routing number, SWIFT/BIC, address.
WISE_ACCOUNT_NAME="Your Name or Business Name"
WISE_ACCOUNT_NUMBER=""
WISE_ROUTING_NUMBER=""
WISE_SWIFT_BIC=""
WISE_BANK_ADDRESS=""
WISE_API_TOKEN="from Wise: Settings -> Integrations and tools -> API tokens (Business account only)"
# PEM-formatted public key Wise gives you for verifying webhook signatures.
WISE_WEBHOOK_PUBLIC_KEY=""
# Dollars of tolerance for incoming-wire fees before a payment is flagged "underpaid".
PAYMENT_TOLERANCE_USD="8"

# Transactional email (PRD §8) — Resend (https://resend.com). Leave blank to log
# emails to the server console instead of sending (useful for local development).
RESEND_API_KEY=""
EMAIL_FROM="Wyndralore <hello@wyndralore.com>"

# Google AdSense publisher/client ID (ca-pub-XXXXXXXXXXXXXXXX from your AdSense account).
# Leave blank to disable the AdSense loader script entirely.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX from analytics.google.com -> Admin ->
# Data Streams -> your web stream). Leave blank to disable GA entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# GA4 Measurement Protocol API secret — server-side `purchase` events from the payment webhook,
# same reason as META_CAPI_ACCESS_TOKEN below (webhook has no browser to fire gtag from). Generate
# in analytics.google.com -> Admin -> Data Streams -> your web stream -> Measurement Protocol API
# secrets -> Create. Server-only secret (NO NEXT_PUBLIC_ prefix). Leave blank to disable; needs
# NEXT_PUBLIC_GA_MEASUREMENT_ID set too.
GA4_API_SECRET=""

# Meta (Facebook) Pixel ID for ad conversion tracking. Find it in Meta Events Manager ->
# Data Sources -> your pixel (a ~15-digit number). Leave blank to disable the pixel entirely
# (nothing is injected). Must be prefixed NEXT_PUBLIC_ so it's readable in the browser.
NEXT_PUBLIC_META_PIXEL_ID=""

# Meta Conversions API access token — server-side Purchase events from the payment webhook
# (accurate ad ROAS tracking). Generate in Meta Events Manager -> your pixel -> Settings ->
# Conversions API -> Generate access token. Server-only secret (NO NEXT_PUBLIC_ prefix). Leave
# blank to disable server-side conversion tracking; needs NEXT_PUBLIC_META_PIXEL_ID set too.
META_CAPI_ACCESS_TOKEN=""

# Lemon Squeezy (payment processor — one-time card checkout, replaces manual Wise wire as the
# primary path on /pricing). Settings -> API for the key, Settings -> General for the store id.
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
# Settings -> Webhooks -> create one pointed at /api/webhooks/lemonsqueezy, subscribe to
# order_created, and set this to the signing secret you choose there.
LEMONSQUEEZY_WEBHOOK_SECRET=""
# Variant IDs (NOT product IDs — each product has a separate underlying variant id; look it up
# via GET /v1/variants?filter[product_id]=<id> if the dashboard only shows the product id).
LEMONSQUEEZY_VARIANT_MONTHLY=""
LEMONSQUEEZY_VARIANT_YEARLY=""
LEMONSQUEEZY_VARIANT_LIFETIME=""
# One-time $2.99 single AI deep reading, for non-members. Same variant-id lookup as above.
LEMONSQUEEZY_VARIANT_AI_SINGLE=""
# One-time $1.99 "extra AI reading" add-on, sold once a member's monthly free AI-deep-read
# quota is used up (still cheaper than the $2.99 non-member one-time price). Same
# GET /v1/variants?filter[product_id]=<id> lookup as the plan variants above.
LEMONSQUEEZY_VARIANT_AI_OVERAGE=""

# Paddle (payment processor for the core product line — membership + AI reads — after Lemon
# Squeezy rejected the store application; NOT used for the paused Masters marketplace, which
# stays on its own dormant Lemon Squeezy code path). Sandbox key from Developer Tools ->
# Authentication in the Paddle dashboard.
PADDLE_API_KEY=""
PADDLE_ENVIRONMENT="sandbox" # "sandbox" | "production"
# Developer Tools -> Notifications -> create a destination pointed at /api/webhooks/paddle,
# subscribe to transaction.completed, and set this to the notification's signing secret.
PADDLE_WEBHOOK_SECRET=""
# Public, safe to expose to the browser (hence NEXT_PUBLIC_) — Developer Tools -> Authentication
# -> client-side tokens. Powers the Paddle.js checkout overlay.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
NEXT_PUBLIC_PADDLE_ENVIRONMENT="sandbox"
# Price IDs (Catalog -> a product -> its price) — one-time (non-recurring) prices, matching the
# site's "no auto-renewal" model.
PADDLE_PRICE_MONTHLY=""
PADDLE_PRICE_YEARLY=""
PADDLE_PRICE_LIFETIME=""
PADDLE_PRICE_AI_SINGLE=""
PADDLE_PRICE_AI_OVERAGE=""
# First-purchase discounts (Catalog -> Discounts), flat amount off, each restricted to its plan's
# price id — Monthly $9.90 -> $5.00, Yearly $49 -> $39. Eligibility (has this user ever paid
# before?) is decided in our own code (isFirstTimeBuyer), not by a Paddle usage-limit counter.
PADDLE_DISCOUNT_FIRSTMONTH=""
PADDLE_DISCOUNT_FIRSTYEAR=""

# Anthropic (Claude) — powers the AI deep-reading feature. Get a key from
# https://console.anthropic.com/settings/keys. Leave blank to disable the feature entirely
# (routes return a clear "not configured" error instead of crashing).
ANTHROPIC_API_KEY=""

# "Meet Our Masters" storefront (2 LS products, shared across every master — attribution happens
# via checkout custom_data, same pattern as the AI-read add-ons above, NOT one LS product per
# master). Same GET /v1/variants?filter[product_id]=<id> lookup as the other variant ids.
LEMONSQUEEZY_VARIANT_MASTER_AI_STYLE=""    # $9.90 AI-in-her-style reading
LEMONSQUEEZY_VARIANT_MASTER_LIVE_VOICE=""  # $39 personal voice/video reading

# Vercel Blob — stores master-recorded delivery audio/video for the $39 live-voice product.
# Private-access store; auto-populated by `vercel blob create-store <name> --access private`,
# already set in Vercel Production/Preview/Development — nothing to do for local dev beyond
# `vercel env pull` if this file's placeholder isn't enough.
BLOB_READ_WRITE_TOKEN=""

# Vercel Cron auth (see vercel.json) — Vercel sends this as a Bearer token when it invokes a cron
# route, so the route can verify the request actually came from Vercel Cron and not a random hit
# on the URL. Generate any long random string; already set in Vercel Production/Preview/Development.
CRON_SECRET=""
