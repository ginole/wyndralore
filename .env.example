# Copy this file to .env and fill in real values before deploying.

# Postgres connection strings (e.g. from Vercel Storage / Neon).
# DATABASE_URL: pooled connection, used by the app at runtime.
# DATABASE_URL_UNPOOLED: direct connection, used only for `prisma migrate` (see schema.prisma
# `directUrl`) — pooled/pgbouncer connections can't run schema migrations reliably.
DATABASE_URL="postgresql://user:password@host-pooler:5432/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth — used to sign user + admin session cookies. Generate a long random string.
SESSION_SECRET="replace-with-a-long-random-string"

# Admin panel (PRD §5.4) — password for the /admin dashboard.
ADMIN_PASSWORD="replace-with-a-strong-password"

# Wise payments (PRD §5) — from your Wise account.
WISE_ACCOUNT_NAME="Your Business Name"
WISE_ACCOUNT_NUMBER="Your account number / IBAN, as shown to payers"
WISE_API_TOKEN="from Wise: Settings -> Integrations and tools -> API tokens"
# PEM-formatted public key Wise gives you for verifying webhook signatures.
WISE_WEBHOOK_PUBLIC_KEY=""

# Transactional email (PRD §8) — Resend (https://resend.com). Leave blank to log
# emails to the server console instead of sending (useful for local development).
RESEND_API_KEY=""
EMAIL_FROM="Wyndralore <hello@wyndralore.com>"
