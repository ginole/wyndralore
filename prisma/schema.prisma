generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) — used at runtime
  directUrl = env("DATABASE_URL_UNPOOLED") // direct connection — used for migrations
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  plan          String    @default("free") // free | monthly | yearly | lifetime
  planExpiresAt DateTime?

  // Server-side free-tier quota (PRD §4.1), mirrors the localStorage logic used pre-auth.
  dailyDrawsUsed      Int     @default(0)
  bonusShareUsedToday Int     @default(0) // 0 or 1 (max 1 share bonus / day)
  bonusAdUsedToday    Int     @default(0) // 0-3 (max 3 ad bonuses / day)
  quotaDate           String? // client-local YYYY-MM-DD these counters belong to

  // AI deep-reading quota (AI-reading PRD §2). Lemon Squeezy plans are one-time payments, not
  // real subscriptions, so there's no billing-cycle object to anchor resets to — instead we
  // roll a 30-day window forward from aiQuotaCycleStart, which is (re)set to `paidAt` whenever
  // a plan purchase activates/renews premium. Extra reads bought via the $1.99 overage
  // one-time purchase just increment aiExtraReadsAvailable and don't touch the cycle.
  aiDeepReadsUsed       Int       @default(0)
  aiQuotaCycleStart     DateTime?
  aiExtraReadsAvailable Int       @default(0)

  // Password reset (forgot-password flow). We store a hash of the token, not the raw
  // value — the raw token only ever lives in the emailed link.
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?

  // True for accounts auto-created by the admin creator-outreach flow that the creator
  // hasn't claimed yet (they were given premium but have no password of their own). Lets
  // a re-invite re-issue a fresh claim link, and is cleared once they set a password.
  isPlaceholder Boolean @default(false)

  // Referral / invite-a-friend loop. `referralCode` is this user's own shareable code
  // (lazily assigned). `premiumSpreadCredits` are earned rewards — each one unlocks a single
  // otherwise-paid PREMIUM spread (Love/Career/Celtic Cross). `referredByCode` records who
  // invited this account (set once, at registration), and `referralRewarded` guards that a
  // given referred account only ever pays out its inviter's +3 reward one time.
  referralCode         String? @unique
  premiumSpreadCredits Int     @default(0)
  referredByCode       String?
  referralRewarded     Boolean @default(false)

  // Auto-renewing Paddle subscription (the "Subscribe & save" pricing option). At most one active
  // subscription per user. While active, planExpiresAt is kept aligned to the Paddle billing
  // period; cancelling just flips autoRenew off and access lapses naturally at currentPeriodEnd.
  subscriptionId     String?   @unique // Paddle sub_... id
  subscriptionStatus String? // active | canceled | past_due | paused | trialing
  currentPeriodEnd   DateTime? // Paddle current_billing_period.ends_at
  autoRenew          Boolean   @default(false)

  createdAt      DateTime        @default(now())
  orders         Order[]
  journalEntries JournalEntry[]
  creatorInvites CreatorInvite[]

  // "Meet Our Masters" marketplace: a User may BE a master (their storefront profile) and/or
  // BUY from masters (their storefront orders). Both optional relations.
  masterProfile MasterProfile?
  masterOrders  MasterOrder[]
}

// Saved readings for Premium members (PRD §4.2). Kept even after a plan lapses so a
// re-subscribe reveals past readings again (召回钩子, PRD §4.4).
model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  spread    String // spread slug
  theme     String // general | love | career | wellness
  question  String?
  note      String? // user's own written note
  cards     String // JSON: [{ position, cardId, orientation }]
  aiReading String? // the generated AI deep-reading text, if one was revealed for this reading
  createdAt DateTime @default(now())

  @@index([userId])
}

model Order {
  id            String    @id @default(cuid())
  code          String    @unique // WL-XXXX
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  plan          String // monthly | yearly | lifetime | ai_overage
  kind          String    @default("plan") // plan | ai_overage — ai_overage never touches user.plan/planExpiresAt
  amountUsd     Float
  status        String    @default("pending") // pending | awaiting_confirmation | paid | underpaid | expired
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  paidAt        DateTime?
  paidAmountUsd Float?
  affiliateId   String? // Lemon Squeezy affiliate/influencer id, passed through custom_data (AI-reading PRD §3)

  webhookEvents WiseWebhookEvent[]

  @@index([userId])
  @@index([status])
}

// Minimal draw log for the admin dashboard (PRD §5.4). Only logged-in draws are captured
// here — anonymous/localStorage draws aren't sent to the server.
model DrawEvent {
  id        String   @id @default(cuid())
  userId    String?
  createdAt DateTime @default(now())
}

// Lightweight self-hosted analytics (PRD §9). One row per tracked event; `props` holds
// event-specific JSON (e.g. { plan } for pricing funnel steps). Privacy-friendly: no PII,
// visitors identified only by an anonymous client id stored in a first-party cookie.
model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String // e.g. visit, signup, reading_completed, share_click, ad_completed, pricing_view, order_created, payment_completed
  anonId    String? // anonymous visitor id (cookie), for funnel stitching
  userId    String?
  props     String? // JSON blob of extra properties
  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
}

// Audit trail for the admin "Creator Outreach" flow: one row per invite sent, so the admin
// panel can show who was granted free premium, with which affiliate link, and whether the
// (placeholder) account was later claimed.
model CreatorInvite {
  id            String   @id @default(cuid())
  email         String
  affiliateLink String
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  wasNewAccount Boolean  @default(false) // true if a placeholder account was created for this invite
  planGranted   String // the plan the account ended up with after the invite (may be unchanged if already better)
  emailSent     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// Brute-force protection for the admin login. One row per client IP (hashed). Tracks failed
// attempts in the current window and escalating lockouts (3 fails -> 1h, next 3 -> 24h).
model AdminLoginThrottle {
  id            String    @id @default(cuid())
  ipHash        String    @unique // sha256(ip + SESSION_SECRET), never the raw IP
  failedCount   Int       @default(0) // consecutive failures since the last lockout/success
  lockoutCount  Int       @default(0) // how many times this IP has been locked out (escalation tier)
  lockedUntil   DateTime? // if set and in the future, all attempts are rejected
  lastAttemptAt DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([lockedUntil])
}

// Generic fixed-window rate limiter (lib/rateLimit.ts). One row per (bucket + hashed identity)
// — e.g. an IP hitting the free AI-summary endpoint, or an IP attempting login. Backed by the
// DB rather than in-memory counters because the app runs on Vercel serverless: many short-lived
// instances handle requests and don't share memory, so an in-memory limiter would leak through.
// The identity (IP/email) is hashed with SESSION_SECRET before storage — never persisted raw.
model RateLimit {
  key         String   @id // sha256(bucket + identity + SESSION_SECRET)
  count       Int      @default(0)
  windowStart DateTime
  updatedAt   DateTime @updatedAt

  @@index([windowStart])
}

// A tarot creator's storefront in the "Meet Our Masters" marketplace. Onboarded by an admin
// (like the creator-outreach flow); the underlying account is a normal User. Holds both the
// public storefront fields and the private AI-style + payout config.
model MasterProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  handle        String   @unique // storefront URL: /masters/[handle]
  displayName   String
  tagline       String? // one-line credo shown on her card/altar
  photoUrl      String?
  channelUrl    String? // YouTube/TikTok/IG — the "as seen on" badge
  followerTier  String? // internal ordering only, never shown
  styleTone     String   @default("gentle") // gentle | direct | playful | poetic (AI voice)
  focusAreas    String   @default("[]") // JSON string[] — love/career/shadow/...
  voiceSamples  String   @default("[]") // JSON string[] — few-shot phrases for AI style
  avoidTopics   String?
  dailyCapacity Int      @default(5) // max live_voice orders/day (anti-oversell)
  slaHours      Int      @default(48) // live_voice delivery deadline
  vacationMode  Boolean  @default(false) // pause live_voice intake; AI layer unaffected
  deepLinkUrl   String? // her external $151 booking link (hidden if null)
  payoutMethod  String? // paypal | wise (optional at onboarding)
  payoutHandle  String? // email / phone for the payout method
  strikeCount   Int      @default(0) // missed-SLA strikes (3 -> paused)
  status        String   @default("pending_review") // pending_review | active | paused
  createdAt     DateTime @default(now())

  orders MasterOrder[]
  ledger LedgerEntry[]

  @@index([status])
}

// One purchase from a master's storefront — distinct from the membership `Order`. Created at
// checkout time as `pending`; the Lemon Squeezy webhook confirms payment. `live_voice` then runs
// the hold-and-release flow (deliver within SLA or auto-refund); `ai_style` is delivered
// instantly on payment, so it settles without an escrow hold.
model MasterOrder {
  id                   String        @id @default(cuid())
  code                 String        @unique // WL-M-XXXX
  masterId             String
  master               MasterProfile @relation(fields: [masterId], references: [id])
  buyerId              String
  buyer                User          @relation(fields: [buyerId], references: [id])
  kind                 String // ai_style | live_voice
  question             String? // buyer's optional note/question, shown to the master for context
  amountUsd            Float
  commissionPct        Float // snapshot at purchase (0.5 | 0.7)
  status               String        @default("pending") // pending|paid|delivered|released|refunded
  lsOrderId            String? // Lemon Squeezy's own order id — needed to call their refund API
  deliverBy            DateTime? // paidAt + slaHours (live_voice only)
  deliveredAt          DateTime?
  deliveryUrl          String? // stored audio/video blob URL (private)
  disputeUntil         DateTime? // deliveredAt + 72h; ledger releases after this
  uploadTokenHash      String? // authorizes the master's tokenized upload page (single-use)
  uploadTokenExpiresAt DateTime?
  listenTokenHash      String? // authorizes the buyer's tokenized listen page (long-lived)
  listenTokenExpiresAt DateTime?
  cardsDrawn           String? // ai_style only — JSON: [{ position, cardId, orientation }], set once the buyer hand-draws (see recordAiStyleDraw)
  aiReadingText        String? // ai_style only — the generated reading, ready the moment the buyer's redirect lands
  createdAt            DateTime      @default(now())
  paidAt               DateTime?

  ledgerEntry LedgerEntry?

  @@index([masterId])
  @@index([status])
}

// The master's earned commission for one order, and where it sits in the
// held -> available -> requested -> paid_out flow (or void on refund). amountUsd is the master's
// cut (commissionPct * order price); the platform absorbs the Lemon Squeezy fee out of its own share.
model LedgerEntry {
  id          String        @id @default(cuid())
  masterId    String
  master      MasterProfile @relation(fields: [masterId], references: [id])
  orderId     String        @unique
  order       MasterOrder   @relation(fields: [orderId], references: [id])
  amountUsd   Float
  status      String        @default("held") // held | available | requested | paid_out | void
  availableAt DateTime?
  requestedAt DateTime?
  paidOutAt   DateTime?
  createdAt   DateTime      @default(now())

  @@index([masterId, status])
}

model WiseWebhookEvent {
  id            String   @id @default(cuid())
  eventKey      String   @unique // dedupe key derived from the Wise payload
  rawPayload    String // full JSON payload, kept for dispute resolution (PRD §5.2)
  receivedAt    DateTime @default(now())
  status        String // matched | unmatched | duplicate | underpaid | overpaid
  orderId       String?
  order         Order?   @relation(fields: [orderId], references: [id])
  amountUsd     Float?
  referenceText String?
  note          String?

  @@index([status])
}
